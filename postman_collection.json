{
  "info": {
    "name": "UniFAST-TDP Scholarship Management API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for Student, Secretary, and Admin headless API endpoints."
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "application_id",
      "value": "",
      "type": "string"
    },
    {
      "key": "user_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Student",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Juan Dela Cruz\",\n  \"email\": \"student@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/register",
              "host": ["{{base_url}}"],
              "path": ["api", "register"]
            }
          }
        },
        {
          "name": "Register Secretary",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Secretary User\",\n  \"email\": \"secretary@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"secretary\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/register",
              "host": ["{{base_url}}"],
              "path": ["api", "register"]
            }
          }
        },
        {
          "name": "Register Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Admin User\",\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/register",
              "host": ["{{base_url}}"],
              "path": ["api", "register"]
            }
          }
        },
        {
          "name": "Login Student",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"student@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/login",
              "host": ["{{base_url}}"],
              "path": ["api", "login"]
            }
          }
        },
        {
          "name": "Login Secretary",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"secretary@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/login",
              "host": ["{{base_url}}"],
              "path": ["api", "login"]
            }
          }
        },
        {
          "name": "Login Admin",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/login",
              "host": ["{{base_url}}"],
              "path": ["api", "login"]
            }
          }
        }
      ]
    },
    {
      "name": "Student Job",
      "item": [
        {
          "name": "POST Apply",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"last_name\": \"Dela Cruz\",\n  \"first_name\": \"Juan\",\n  \"middle_name\": \"Santos\",\n  \"maiden_name\": \"Lopez\",\n  \"birthdate\": \"2004-03-12\",\n  \"sex\": \"male\",\n  \"civil_status\": \"single\",\n  \"contact_number\": \"09171234567\",\n  \"email\": \"student@example.com\",\n  \"street_address\": \"123 Sampaloc St\",\n  \"barangay\": \"Sampaloc\",\n  \"municipality\": \"Quezon City\",\n  \"province\": \"Metro Manila\",\n  \"region\": \"NCR\",\n  \"school_id\": \"PUP12345\",\n  \"year_level\": \"2nd Year\",\n  \"tribal_membership\": \"None\",\n  \"father_name\": \"Jose Dela Cruz\",\n  \"mother_name\": \"Maria Dela Cruz\",\n  \"household_income\": 350000,\n  \"is_indigent\": true,\n  \"has_cor\": true\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/student/applications",
              "host": ["{{base_url}}"],
              "path": ["api", "student", "applications"]
            }
          }
        },
        {
          "name": "GET My Applications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/student/applications",
              "host": ["{{base_url}}"],
              "path": ["api", "student", "applications"]
            }
          }
        },
        {
          "name": "PUT Update My Application",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"municipality\": \"Makati City\",\n  \"province\": \"Metro Manila\",\n  \"street_address\": \"456 Mabini St\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/student/applications/{{application_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "student", "applications", "{{application_id}}"]
            }
          }
        },
        {
          "name": "DELETE My Application",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/student/applications/{{application_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "student", "applications", "{{application_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Secretary Job",
      "item": [
        {
          "name": "GET All Pending Applications",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/applications?status=pending",
              "host": ["{{base_url}}"],
              "path": ["api", "applications"],
              "query": [
                {
                  "key": "status",
                  "value": "pending"
                }
              ]
            }
          }
        },
        {
          "name": "PATCH Update Status (Approved)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"approved\",\n  \"remarks\": \"Verified documents and approved.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/applications/{{application_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["api", "applications", "{{application_id}}", "status"]
            }
          }
        },
        {
          "name": "PATCH Update Status (Rejected)",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"rejected\",\n  \"remarks\": \"Incomplete requirements.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/applications/{{application_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["api", "applications", "{{application_id}}", "status"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin Job",
      "item": [
        {
          "name": "GET Full Database Export",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/records",
              "host": ["{{base_url}}"],
              "path": ["api", "admin", "records"]
            }
          }
        },
        {
          "name": "DELETE Remove Invalid Record",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/admin/scholarship-applications/{{application_id}}",
              "host": ["{{base_url}}"],
